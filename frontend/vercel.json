{
  "version": 2,
  "name": "ai-cv-checker-frontend",
  "buildCommand": "echo 'Frontend is a static site - no build needed'",
  "outputDirectory": "./",
  "public": false,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/(?!.*\\.(js|css|json|png|jpg|jpeg|gif|svg|ico|woff|woff2)$)(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VERCEL": "1"
  }
}
