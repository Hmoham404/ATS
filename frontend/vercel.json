{
  "version": 2,
  "name": "AI CV Checker Frontend",
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "public": false,
  "headers": [
    {
      "source": "/.*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/[^.]+$",
      "dest": "/index.html"
    }
  ]
}
